# Production .gitignore for LAWS Operational Deployment
# Excludes sensitive, large, and temporary files from Git

# Environment variables
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
ENV/
env/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs (except .gitkeep)
logs/*.csv
logs/*.log
!logs/.gitkeep

# Model checkpoints (too large for Git; use Git LFS or manage separately)
checkpoints/*.pkl
checkpoints/*.pth
checkpoints/*.pt
!checkpoints/.gitkeep

# Data files
data/
*.h5
*.hdf5
*.nc
*.dat
raw_signals/

# Test artifacts
test_output/
test_logs/
*.tmp

# OS
.DS_Store
Thumbs.db
.swp

# Scratch and experimental scripts
scratch_*.py
test_*.py
debug/
experiments/
