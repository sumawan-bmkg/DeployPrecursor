# ═══════════════════════════════════════════════════════════════════
# BMKG LAWS — Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and configure for your deployment:
#   cp .env.example .env
#
# All variables are optional; defaults are shown below.
# ═══════════════════════════════════════════════════════════════════

# Device selection: 'cuda' for NVIDIA GPU, 'cpu' for CPU-only
LAWS_DEVICE=cuda

# API server binding
LAWS_HOST=0.0.0.0
LAWS_PORT=8000

# Logging level: debug, info, warning, error
LAWS_LOG_LEVEL=info

# HDF5 data directory (optional; override if data is stored elsewhere)
# LAWS_H5_DIR=/path/to/h5/scalogram/data
