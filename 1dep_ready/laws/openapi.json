{"openapi":"3.1.0","info":{"title":"BMKG LAWS — Geomagnetic lithosphere activity warning","description":"\n**Lithosphere Activity Warning System (LAWS)**\n\nHybrid V9.5 + LightGBM Tabular pipeline:\n- **V9.5 PIMES**: Gatekeeper (Kp/Dst storm filter) + Detection + Azimuth\n- **LightGBM Huber Regressor**: Magnitude estimation (53 ULF2 features)\n\nEndpoints:\n- `POST /predict` — Full hybrid prediction (V9.5 gate → LGBM magnitude)\n- `GET /health` — System health check\n- `GET /stations` — Station list and configuration\n","version":"9.5.1"},"paths":{"/health":{"get":{"tags":["System"],"summary":"Health Check","description":"System health and model status.","operationId":"health_check_health_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HealthResponse"}}}}}}},"/stations":{"get":{"tags":["System"],"summary":"List Stations","description":"Station configuration and prior status.","operationId":"list_stations_stations_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/predict":{"post":{"tags":["Inference"],"summary":"Predict Hybrid","description":"Full hybrid V9.5 → LightGBM pipeline (Real-Time In-Memory).","operationId":"predict_hybrid_predict_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/PredictRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/PredictionResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/predict/mag":{"post":{"tags":["Inference"],"summary":"Predict Magnitude","description":"LightGBM-only magnitude estimation from 53 ULF2 features.\n\nBypasses V9.5 gatekeeper and HDF5 loading.\nFor direct magnitude estimation with pre-computed features.","operationId":"predict_magnitude_predict_mag_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/MagPredictRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/MagResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}}},"components":{"schemas":{"HTTPValidationError":{"properties":{"detail":{"items":{"$ref":"#/components/schemas/ValidationError"},"type":"array","title":"Detail"}},"type":"object","title":"HTTPValidationError"},"HealthResponse":{"properties":{"status":{"type":"string","title":"Status"},"models_loaded":{"type":"boolean","title":"Models Loaded"},"startup_time":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Startup Time"},"load_duration_s":{"anyOf":[{"type":"number"},{"type":"null"}],"title":"Load Duration S"},"device":{"type":"string","title":"Device"},"lgbm_checkpoint":{"type":"string","title":"Lgbm Checkpoint"},"lgbm_features":{"type":"integer","title":"Lgbm Features"},"v95_checkpoint":{"type":"string","title":"V95 Checkpoint"},"h5_dates_available":{"type":"integer","title":"H5 Dates Available"},"priors_loaded":{"type":"boolean","title":"Priors Loaded"},"storm_config":{"additionalProperties":true,"type":"object","title":"Storm Config"}},"type":"object","required":["status","models_loaded","startup_time","load_duration_s","device","lgbm_checkpoint","lgbm_features","v95_checkpoint","h5_dates_available","priors_loaded","storm_config"],"title":"HealthResponse","description":"System health check response."},"MagPredictRequest":{"properties":{"ulf2_features":{"items":{"type":"number"},"type":"array","maxItems":53,"minItems":53,"title":"Ulf2 Features","description":"53 ULF2 tabular features for magnitude estimation","examples":[[0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5,0.5