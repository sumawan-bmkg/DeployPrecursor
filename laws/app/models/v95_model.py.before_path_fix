#!/usr/bin/env python3
"""
v95_model.py — V9.5 PIMES (Physics-Informed Magnitude Estimation System) inference wrapper.

Architecture: MultiTaskScalogramV9_5_Bayesian
  - V8 backbone (EfficientNet-B1 + BiGRU + GNN + cosmic gating) — frozen
  - BayesianAzimuthHeadV95 with:
      * Station embedding (32-D)
      * ConditionalTemporalAttention (station-aware physics features)
      * Prior projection (360 → 160)
      * Image projection (512 → 128)
      * Gated fusion → [sin, cos] azimuth

V9.5 serves as:
  1. Gatekeeper: Detection + Azimuth + Storm filter
  2. Azimuth estimator (station-aware with Bayesian priors)

Magnitude estimation is delegated to V8 (better MAE).
"""

import sys
import logging
from pathlib import Path
from typing import Optional, Tuple

import torch
import torch.nn.functional as F

logger = logging.getLogger(__name__)

# Paths
_V95_MODEL_PATH = (
    Path(__file__).resolve().parents[2] / '..' / 'Bayesian' / 'V9_5_Bayesian_Model.py'
)


def _import_v95_model():
    import importlib.util
    spec = importlib.util.spec_from_file_location(
        'V9_5_Bayesian_Model', str(_V95_MODEL_PATH)
    )
    mod = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(mod)
    return mod.MultiTaskScalogramV9_5_Bayesian


class V95PimesInference:
    """
    V9.5 PIMES inference wrapper.

    Usage:
        model = V95PimesInference(checkpoint_path, prior_loader, device='cuda')
        result = model.predict(x_img, x_cosmic, station_id, prior_vec)
    """

    def __init__(
        self,
        checkpoint_path: Path,
        device: str = 'cpu',
        strict_load: bool = False,
    ):
        self.device = device

        ModelClass = _import_v95_model()
        self.model = ModelClass()
        self.model = self.model.to(device)
        self.model.eval()

        # Load checkpoint
        state = torch.load(str(checkpoint_path), map_location=device)
        if isinstance(state, dict):
            sd = (
                state.get('model_state_dict')
                or state.get('state_dict')
                or state
            )
        else:
            sd = state

        # Strip 'module.' prefix
        sd_clean = {k.replace('module.', ''): v for k, v in sd.items()}

        missing, unexpected = self.model.load_state_dict(
            sd_clean, strict=strict_load
        )
        if missing:
            logger.warning('V9.5 missing keys: %s', missing)
        if unexpected:
            logger.warning('V9.5 unexpected keys: %s', unexpected)

        self.model.eval()
        logger.info('V9.5 model loaded from %s', checkpoint_path)

    @torch.no_grad()
    def predict(
        self,
        x_img: torch.Tensor,
        x_cosmic: torch.Tensor,
        station_id: torch.Tensor,
        prior_vec: torch.Tensor,
    ) -> dict:
        """
        Run V9.5 inference.

        Args:
            x_img: (1, 3, 128, 1440)
            x_cosmic: (1, 2) [Kp_norm, Dst_norm]
            station_id: (1,) int index into station embedding table
            prior_vec: (1, 360) station azimuth prior

        Returns:
            dict with:
                detection_prob: float — P(class=1)
                detection_class: int — 0 or 1
                azimuth_deg: float — azimuth in degrees [0, 360)
                azimuth_sin: float
                azimuth_cos: float
                gate_value: float — gating network mean activation
                magnitude: float — from V8 frozen head (less accurate than V8 standalone)
        """
        x_img = x_img.to(self.device)
        x_cosmic = x_cosmic.to(self.device)
        station_id = station_id.to(self.device)
        prior_vec = prior_vec.to(self.device)

        det_logits, mag_logits, azm_unit, gate_val = self.model(
            x_img, x_cosmic, prior_vec, station_id
        )

        # Detection
        det_probs = F.softmax(det_logits, dim=1)
        det_prob = float(det_probs[0, 1].item())
        det_class = int(torch.argmax(det_probs, dim=1).item())

        # Azimuth unit vector → degrees
        azm_sin = float(azm_unit[0, 0].item())
        azm_cos = float(azm_unit[0, 1].item())
        azm_rad = torch.atan2(azm_unit[0, 0], azm_unit[0, 1])
        azm_deg = float((torch.rad2deg(azm_rad) % 360).item())

        # Magnitude (V8 frozen head — use V8 standalone for better accuracy)
        mag_probs = F.softmax(mag_logits, dim=1)

        return {
            'detection_prob': det_prob,
            'detection_class': det_class,
            'azimuth_deg': azm_deg,
            'azimuth_sin': azm_sin,
            'azimuth_cos': azm_cos,
            'gate_value': float(gate_val.item()),
        }

    @torch.no_grad()
    def predict_batch(
        self,
        x_img: torch.Tensor,
        x_cosmic: torch.Tensor,
        station_ids: torch.Tensor,
        prior_vecs: torch.Tensor,
    ) -> dict:
        """
        Batch inference for multiple stations.

        All tensors: (N, ...) where N = number of stations.
        """
        x_img = x_img.to(self.device)
        x_cosmic = x_cosmic.to(self.device)
        station_ids = station_ids.to(self.device)
        prior_vecs = prior_vecs.to(self.device)

        det_logits, mag_logits, azm_unit, gate_val = self.model(
            x_img, x_cosmic, prior_vecs, station_ids
        )

        det_probs = F.softmax(det_logits, dim=1)
        det_probs_np = det_probs[:, 1].cpu().tolist()
        det_classes = torch.argmax(det_probs, dim=1).cpu().tolist()

        azm_rad = torch.atan2(azm_unit[:, 0], azm_unit[:, 1])
        azm_deg = (torch.rad2deg(azm_rad) % 360).cpu().tolist()

        return {
            'detection_probs': det_probs_np,
            'detection_classes': det_classes,
            'azimuths_deg': azm_deg,
            'gate_values': gate_val.cpu().tolist(),
        }
