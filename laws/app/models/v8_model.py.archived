#!/usr/bin/env python3
"""
v8_model.py — V8 (SupCon) model wrapper for LAWS magnitude estimation.

Architecture: MultiTaskScalogramV3_v8
  - Backbone: EfficientNet-B1
  - Temporal: BiGRU
  - Spatial GNN: 2-layer GAT
  - Cosmic gating: MLP
  - Task heads: detection, magnitude (5 bins), azimuth (sincos), SupCon projection

Magnitude head outputs 5 logits → bin centers [0,1,2,3,4] → discretized M.
"""

import sys
import logging
from pathlib import Path
from typing import Optional, Tuple

import torch
import torch.nn.functional as F

logger = logging.getLogger(__name__)

# Dynamically load V8 model class from its source
_V8_MODEL_PATH = Path(__file__).resolve().parents[2] / '..' / 'ScalogramV3_V8_Repository' / 'model' / 'V3_Model_v8.py'


def _import_v8_model():
    import importlib.util
    spec = importlib.util.spec_from_file_location('V3_Model_v8', str(_V8_MODEL_PATH))
    mod = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(mod)
    return mod.MultiTaskScalogramV3_v8


# Magnitude bin centers (5 bins: 0-1, 1-2, 2-3, 3-4, 4-5+)
MAG_BINS = torch.tensor([0.5, 1.5, 2.5, 3.5, 4.5])


def mag_logits_to_value(logits: torch.Tensor) -> torch.Tensor:
    """Convert 5-bin logits to scalar magnitude via softmax-weighted bins."""
    probs = F.softmax(logits, dim=1)
    return (probs * MAG_BINS.to(logits.device)).sum(dim=1, keepdim=True)


class V8SupConInference:
    """
    V8 model wrapper for LAWS magnitude estimation inference.

    Usage:
        model = V8SupConInference(checkpoint_path, device='cuda')
        mag, detection, azimuth, meta = model.predict(x_img, x_cosmic)
    """

    def __init__(
        self,
        checkpoint_path: Path,
        device: str = 'cpu',
        strict_load: bool = False,
    ):
        self.device = device

        # Load model class dynamically
        ModelClass = _import_v8_model()
        self.model = ModelClass(pretrained=False)
        self.model = self.model.to(device)
        self.model.eval()

        # Load checkpoint
        state = torch.load(str(checkpoint_path), map_location=device)
        if isinstance(state, dict):
            sd = (
                state.get('model_state_dict')
                or state.get('state_dict')
                or state
            )
        else:
            sd = state

        # Strip 'module.' prefix if DataParallel
        sd_clean = {}
        for k, v in sd.items():
            k_clean = k.replace('module.', '')
            # Also handle v8._v8. prefix from V9.5 wrapper
            k_clean = k_clean.replace('_v8.', '')
            sd_clean[k_clean] = v

        missing, unexpected = self.model.load_state_dict(
            sd_clean, strict=strict_load
        )
        if missing:
            logger.warning('V8 missing keys: %s', missing)
        if unexpected:
            logger.warning('V8 unexpected keys: %s', unexpected)

        self.model.eval()
        logger.info('V8 model loaded from %s', checkpoint_path)

    @torch.no_grad()
    def predict(
        self,
        x_img: torch.Tensor,
        x_cosmic: Optional[torch.Tensor] = None,
    ) -> dict:
        """
        Run V8 inference.

        Args:
            x_img: (1, 3, 128, 1440) scalogram tensor
            x_cosmic: (1, 2) [Kp_norm, Dst_norm] or None (defaults to zero)

        Returns:
            dict with keys:
                magnitude: float — estimated magnitude
                detection_prob: float — P(class=1) positive detection
                detection_class: int — 0 or 1
                azimuth_sin: float
                azimuth_cos: float
                magnitude_bin_probs: list[float] — 5-bin distribution
        """
        x_img = x_img.to(self.device)
        if x_cosmic is None:
            x_cosmic = torch.zeros(1, 2, device=self.device)
        else:
            x_cosmic = x_cosmic.to(self.device)

        # Forward
        out_detection, out_magnitude, out_azimuth, reg_score, att_weights, proj_vec, v_fusion = (
            self.model(x_img, x_cosmic)
        )

        # Detection
        det_probs = F.softmax(out_detection, dim=1)
        det_prob = float(det_probs[0, 1].item())
        det_class = int(torch.argmax(det_probs, dim=1).item())

        # Magnitude
        mag_value = mag_logits_to_value(out_magnitude)
        mag_bin_probs = F.softmax(out_magnitude, dim=1)[0].cpu().tolist()

        # Azimuth
        azm_sin = float(out_azimuth[0, 0].item())
        azm_cos = float(out_azimuth[0, 1].item())

        return {
            'magnitude': float(mag_value[0, 0].item()),
            'detection_prob': det_prob,
            'detection_class': det_class,
            'azimuth_sin': azm_sin,
            'azimuth_cos': azm_cos,
            'magnitude_bin_probs': mag_bin_probs,
            'reg_score': float(reg_score[0, 0].item()),
        }
