#!/usr/bin/env python3

import os
import gzip
import numpy as np

FILE_PATH = "/opt/pimes/data/raw/SCN/S260611.SCN"

BLOCK_HEADER = 30
RECORD_SIZE = 17
RECORDS_PER_BLOCK = 600

BLOCK_SIZE = BLOCK_HEADER + (RECORD_SIZE * RECORDS_PER_BLOCK)


def twos_complement(vals, bits):
    vals = vals.astype(np.int64)

    mask = vals >= (1 << (bits - 1))

    vals[mask] -= (1 << bits)

    return vals


def read_uint24_le(arr):
    return (
        arr[:, 0].astype(np.uint32)
        + (arr[:, 1].astype(np.uint32) << 8)
        + (arr[:, 2].astype(np.uint32) << 16)
    )


def load_file(path):

    if path.endswith(".gz"):
        with gzip.open(path, "rb") as f:
            return f.read()

    with open(path, "rb") as f:
        return f.read()


def main():

    raw = load_file(FILE_PATH)

    print()
    print("FILE:", FILE_PATH)
    print("FILE SIZE:", len(raw))
    print()

    data = np.frombuffer(raw, dtype=np.uint8)

    n_blocks = len(data) // BLOCK_SIZE

    print("BLOCK SIZE      :", BLOCK_SIZE)
    print("BLOCKS FOUND    :", n_blocks)
    print("REMAINDER BYTES :", len(data) % BLOCK_SIZE)
    print()

    payload_parts = []

    for i in range(n_blocks):

        start = i * BLOCK_SIZE

        block = data[start:start + BLOCK_SIZE]

        payload_parts.append(block[BLOCK_HEADER:])

    payload = np.concatenate(payload_parts)

    n_records = len(payload) // RECORD_SIZE

    payload = payload[: n_records * RECORD_SIZE]

    records = payload.reshape((n_records, RECORD_SIZE))

    print("PARSED RECORDS:", n_records)
    print()

    H_raw = read_uint24_le(records[:, 0:3])

    D_raw = read_uint24_le(records[:, 3:6])

    Z_raw = read_uint24_le(records[:, 6:9])

    IX_raw = (
        records[:, 9].astype(np.uint32)
        + (records[:, 10].astype(np.uint32) << 8)
    )

    IY_raw = (
        records[:, 11].astype(np.uint32)
        + (records[:, 12].astype(np.uint32) << 8)
    )

    TempS_raw = (
        records[:, 13].astype(np.uint32)
        + (records[:, 14].astype(np.uint32) << 8)
    )

    TempP_raw = (
        records[:, 15].astype(np.uint32)
        + (records[:, 16].astype(np.uint32) << 8)
    )

    H = twos_complement(H_raw, 24) * 0.01

    D = twos_complement(D_raw, 24) * 0.01

    Z = twos_complement(Z_raw, 24) * 0.01

    IX = twos_complement(IX_raw, 16) * 0.1

    IY = twos_complement(IY_raw, 16) * 0.1

    TempS = twos_complement(TempS_raw, 16) * 0.01

    TempP = twos_complement(TempP_raw, 16) * 0.01

    def stats(name, arr):

        print(name)

        print("MIN :", np.nanmin(arr))
        print("MAX :", np.nanmax(arr))
        print("MEAN:", np.nanmean(arr))
        print("STD :", np.nanstd(arr))
        print()

    stats("H", H)

    stats("D", D)

    stats("Z", Z)

    print("FIRST 10 SAMPLES")
    print()

    for i in range(min(10, len(H))):

        print(
            i,
            H[i],
            D[i],
            Z[i]
        )

    print()

    print("EXPECTED DAILY RECORDS:", 86400)

    print("ACTUAL RECORDS:", n_records)

    if n_records == 86400:

        print("STATUS: DAILY FILE OK")

    else:

        print("STATUS: RECORD COUNT MISMATCH")


if __name__ == "__main__":
    main()
